# Resend — transactionele e-mail voor het contact-/offerteformulier.
# Maak een account op https://resend.com, verifieer je domein (aldesign.nl)
# en plak hier je API-key.
RESEND_API_KEY=

# Waar de offerteaanvragen naartoe gestuurd worden (standaard: info@aldesign.nl).
CONTACT_TO_EMAIL=info@aldesign.nl

# Afzender. Moet een geverifieerd domein in Resend zijn, bijv. "AL Design <noreply@aldesign.nl>".
# Voor testen kun je "AL Design <onboarding@resend.dev>" gebruiken.
CONTACT_FROM_EMAIL=AL Design <noreply@aldesign.nl>
